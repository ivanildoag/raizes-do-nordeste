# =============================================================================
# Variáveis de Ambiente - Raízes do Nordeste API
# Copie este arquivo para .env e ajuste os valores conforme necessário
# =============================================================================

# Banco de Dados
DATABASE_URL=jdbc:postgresql://localhost:5432/raizesdonordeste
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# JWT (JSON Web Token)
# IMPORTANTE: Em produção, utilize uma chave segura de pelo menos 256 bits
JWT_SECRET=raizesdonordeste-secret-key-muito-segura-para-producao-2026-chave-256-bits-minimo
JWT_EXPIRATION=86400000

# Servidor
SERVER_PORT=8080

# Fidelidade
PONTOS_POR_REAL=1
